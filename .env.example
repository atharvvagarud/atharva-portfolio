# Canonical production URL used by metadata, sitemap and robots.
SITE_URL=https://atharvagarud.com

# Static contact fallbacks used only when published Site Settings is unavailable.
SITE_EMAIL=
GITHUB_URL=
LINKEDIN_URL=

# Public Sanity identifiers used by the embedded Studio and published client.
# These are not secrets. Never place an API token in a NEXT_PUBLIC variable.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Stable API date shared by every CMS query.
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01

# Server-only secret used to authenticate Sanity revalidation webhooks.
SANITY_REVALIDATE_SECRET=
